{
  "name": "claude-session-manager",
  "version": "1.0.0",
  "description": "Claude Session Manager - 管理和搜索 Claude Code sessions",
  "type": "module",
  "main": "dist-electron/electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:electron\"",
    "dev:client": "vite",
    "dev:electron": "tsx electron/dev.ts",
    "build": "vite build && npm run build:electron",
    "build:electron": "tsx electron/build.ts",
    "electron:dev": "concurrently \"npm run dev:client\" \"npm run dev:electron\"",
    "pack": "npm run build && electron-builder --mac --dir",
    "dist": "npm run build && electron-builder --mac",
    "postinstall": "electron-rebuild || true"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "express": "^5.2.1",
    "glob": "^13.0.6",
    "node-pty": "^1.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/vite": "^4.2.2",
    "@types/express": "^5.0.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.8"
  },
  "build": {
    "appId": "com.claude.session-manager",
    "productName": "Claude Session Manager",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": "dmg",
      "icon": "public/icon.icns"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "extraResources": [],
    "npmRebuild": true,
    "nodeGypRebuild": false
  }
}
